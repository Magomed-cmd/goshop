# Server Configuration
SERVER_PORT=8080
SERVER_HOST=localhost
GIN_MODE=debug

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=goshop_user
DB_PASSWORD=your_secure_password_here
DB_NAME=goshop_db
DB_SSL_MODE=disable
DB_MAX_CONNECTIONS=25
DB_IDLE_CONNECTIONS=5

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_TIMEOUT=5s

# JWT Configuration
JWT_SECRET=your_very_long_secret_key_at_least_32_characters_for_security
JWT_EXPIRATION=24h
REFRESH_TOKEN_EXPIRATION=7d

# S3 / MinIO Configuration
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=goshop
S3_REGION=us-east-1
S3_USE_SSL=false

# OAuth Configuration (Google)
GOOGLE_CLIENT_ID=your_google_client_id_here.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URL=http://localhost:8080/auth/oauth/google/callback

# Logging Configuration
LOG_LEVEL=info
LOG_FORMAT=json
LOG_OUTPUT=stdout

# Application Configuration
ENVIRONMENT=development
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Content-Type,Authorization

# Email Configuration (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM=noreply@goshop.com

# Feature Flags
ENABLE_OAUTH=true
ENABLE_PRODUCT_CACHE=true
ENABLE_REVIEW_CACHE=true
CACHE_TTL=3600

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=1m
